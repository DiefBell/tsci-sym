{
	"name": "@sym.js/example",
	"dependencies": {
		"sym.js": "link:sym.js"
	},
	"devDependencies": {
		"@boperators/cli": "^0.1.0",
		"@boperators/plugin-bun": "^0.1.0",
		"@boperators/plugin-ts-language-server": "^0.1.0",
		"@boperators/plugin-tsc": "^0.1.0",
		"@types/bun": "^1.1.16",
		"boperators": "^0.1.0",
		"ts-patch": "^3.3.0",
		"typescript": "^5.9.3"
	},
	"scripts": {
		"start": "bun run ./src/index.ts",
		"transform": "rm -rf ./transformed && boperate compile --ts-out ./transformed --maps-out ./transformed",
		"start:transformed": "bun run ./transformed/index.ts",
		"build": "tspc",
		"start:built": "node ./dist/index.ts"
	}
}

{
	"name": "@sym.js/example",
	"dependencies": {
		"sym.js": "link:sym.js"
	},
	"devDependencies": {
		"@boperators/cli": "link:@boperators/cli",
		"@boperators/plugin-bun": "link:@boperators/plugin-bun",
		"@boperators/plugin-ts-language-server": "link:@boperators/plugin-ts-language-server",
		"@boperators/plugin-tsc": "link:@boperators/plugin-tsc",
		"@types/bun": "^1.1.16",
		"boperators": "link:boperators",
		"ts-patch": "^3.3.0",
		"typescript": "^5.9.3"
	},
	"scripts": {
		"start": "bun run ./src/index.ts",
		"transform": "rm -rf ./transformed && boperate --ts-out ./transformed --maps-out ./transformed",
		"start:transformed": "bun run ./transformed/src/index.ts",
		"build": "tspc",
		"start:built": "node ./dist/index.ts"
	}
}

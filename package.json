{
	"workspaces": [
		"package",
		"example"
	],
	"scripts": {
		"build": "bun run --filter='*' build",
		"watch": "bun run --filter='*' watch",
		"typecheck": "bun run --filter='*' typecheck",
		"check": "biome check .",
		"check:unsafe": "biome check --write --unsafe .",
		"format": "biome check --write --no-errors-on-unmatched .",
		"prepare": "husky"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.3.14",
		"@boperators/plugin-ts-language-server": "^0.3.1",
		"boperators": "^0.3.1",
		"husky": "^9.1.7",
		"lint-staged": "^16.2.7"
	},
	"lint-staged": {
		"*": "bun run format"
	}
}
